NODE_ENV=development
PORT=3000

# Opcion A - recomendada para produccion (Neon/Render)
DATABASE_URL=postgresql://usuario:password@host:5432/database?sslmode=require

# Opcion B - desarrollo local con Postgres propio
PGHOST=localhost
PGPORT=5434
PGDATABASE=servicio_mantenimiento
PGUSER=postgres
PGPASSWORD=cambiame

# Activa SSL para Neon / bases gestionadas.
PGSSL=false

JWT_SECRET=cambia_esto_por_un_secreto_largo_de_al_menos_16_caracteres
JWT_EXPIRES_IN=8h

# Separado por comas. Soporta wildcard simple con *
# Ejemplo:
# CORS_ORIGINS=http://localhost:5173,https://mi-frontend.vercel.app,https://mi-frontend-git-*.vercel.app
CORS_ORIGINS=http://localhost:5173

RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_MIN=15
