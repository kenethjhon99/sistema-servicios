# Entorno
NODE_ENV=development
PORT=3000

# Base de datos PostgreSQL
PGHOST=localhost
PGPORT=5434
PGDATABASE=servicio_mantenimiento
PGUSER=postgres
PGPASSWORD=cambiame
# Habilitar SSL para BDs gestionadas (Supabase, Neon, RDS).
# Para Postgres local/Docker dejá en false.
PGSSL=false

# JWT — OBLIGATORIO. Mínimo 16 caracteres.
JWT_SECRET=cambia_esto_por_un_secreto_largo_de_al_menos_16_caracteres
JWT_EXPIRES_IN=8h

# CORS — lista separada por comas, o "*" para permitir cualquier origen (sólo dev)
CORS_ORIGINS=http://localhost:5173

# Rate limiting del endpoint /auth/login
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_MIN=15
